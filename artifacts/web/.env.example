# ============================================================
# Star City Living App — Vercel production env var reference
# ============================================================
# Copy these keys into the Vercel dashboard (Project Settings →
# Environment Variables) or run `vercel env add <NAME>`.
# Do NOT commit real values — .env.example stays blank.
# See DEPLOYMENT.md for where to source each value.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Drizzle — pooler connection string) ---
DATABASE_URL=

# --- Web Push / VAPID (required for push notifications) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# --- Resend email (optional — leave blank to disable email) ---
RESEND_API_KEY=

# --- Cron secret (required — Vercel Cron sends as Authorization: Bearer) ---
CRON_SECRET=

# --- WebSocket server (leave blank on Vercel — polling fallback is used) ---
# See DEPLOYMENT.md §WebSocket for rationale (WS-01). Real-time chat
# currently falls back to HTTP polling in production.
NEXT_PUBLIC_WS_URL=
WS_BROADCAST_URL=
