{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "pnpm --filter @workspace/web dev",
    "build": "pnpm --filter @workspace/web build",
    "seed": "pnpm --filter @workspace/scripts seed",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm --filter @workspace/web typecheck",
    "format:check": "prettier --check \"artifacts/web/**/*.{ts,tsx}\" \"lib/**/*.ts\" \"scripts/**/*.ts\"",
    "format": "prettier --write \"artifacts/web/**/*.{ts,tsx}\" \"lib/**/*.ts\" \"scripts/**/*.ts\"",
    "test:ci": "pnpm -r --if-present run test"
  },
  "private": true,
  "devDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "4.2.1",
    "lightningcss-darwin-arm64": "1.31.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.1"
  }
}
